# --- PRODUCTION ENVIRONMENT SETTINGS ---
# Use .env for production settings in cPanel

PORT=5000
NODE_ENV=production

# Frontend API URL (The URL of your website)
NEXT_PUBLIC_API_URL=https://kamrulhasan.info/api
NEXT_PUBLIC_API_BASE_URL=https://kamrulhasan.info

# Database Settings (MySQL)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_cpanel_db_user
MYSQL_PASSWORD=your_cpanel_db_password
MYSQL_DATABASE=your_cpanel_db_name

# Security
JWT_SECRET=your_long_random_jwt_secret_key

# --- MISC ---
# Increase if you have many images or large uploads
NEXT_BODY_LIMIT=10mb

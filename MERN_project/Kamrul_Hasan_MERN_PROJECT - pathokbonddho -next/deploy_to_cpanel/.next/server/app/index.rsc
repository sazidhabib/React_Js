-27T17:16:26.000Z","updatedAt":"2026-03-27T17:16:26.000Z","rowId":767,"resolvedContent":{"id":2,"name":"ad_facebook","slug":"ad-facebook","type":"image","image":"ajp_facebook-1765346447427.webp","imageUrl":"https://pathakbondhu.com/ab","headCode":null,"bodyCode":null,"position":"sidebar","displayPages":null,"startDate":"2025-10-15T00:00:00.000Z","endDate":"2026-03-20T00:00:00.000Z","isActive":true,"maxImpressions":null,"currentImpressions":343,"clickCount":1,"createdAt":"2025-10-14T08:34:28.000Z","updatedAt":"2026-04-02T18:49:25.000Z"}}]},{"id":768,"rowOrder":2,"createdAt":"2026-03-27T17:16:26.000Z","updatedAt":"2026-03-27T17:16:26.000Z","sectionId":270,"Columns":[{"id":3010,"colOrder":1,"width":3,"mergedWith":null,"contentType":"news","tag":"সম্পর্কে","design":null,"contentId":"1765","contentTitle":"মানবিক সমাজ গঠনে কাজ করবে পাঠকবন্ধু তালা শাখা","merged":false,"masterCell":false,"rowSpan":1,"colSpan":1,"masterCellKey":null,"mergedCells":null,"createdAt":"2026-03-27T17:16:26.000Z","updatedAt":"2026-03-27T17:16:26.000Z","rowId":768,"resolvedContent":{"id":1765,"newsHeadline":"মানবিক সমাজ গঠনে কাজ করবে পাঠকবন্ধু তালা শাখা","highlight":"","alternativeHeadline":"","authorId":14,"shortDescription":"সাতক্ষীরার তালায় পাঠকবন্ধুদের প্রথম পরিচয়পর্ব এবং আলোচনা সভা অনুষ্ঠিত হয়েছে। ১০ জুন সোমবার বিকেলে তালা প্রেসক্লাব হলরুমে","content":"$17","leadImage":"images/post_image/arZLk.jpg","thumbImage":"images/post_image/thmb_p1HS7.jpg","imageCaption":"","videoLink":"","newsSchedule":"2026-01-15T14:17:33.000Z","metaTitle":"","metaKeywords":"","metaDescription":"","metaImage":"images/post_image/manbik-smaj-gthne-kaj-krbe-pathkbndhu-tala-sakha72uOW.jpg","status":"published","newsType":"standard","slug":"manbik-smaj-gthne-kaj-krbe-pathkbndhu-tala-sakha","views":873,"createdAt":"2024-09-04T16:56:36.000Z","updatedAt":"2026-04-02T18:49:25.000Z","Tags":[{"id":33,"name":"সম্পর্কে","slug":"relation"}],"Categories":[{"id":3,"name":"কার্যক্রম","path":"activites"}],"Author":{"id":14,"name":"পাঠকবন্ধু"},"GalleryItems":[]}},{"id":3013,"colOrder":2,"width":3,"mergedWith":null,"contentType":"news","tag":"কবিতা","design":"text-inside-image","contentId":"2080","contentTitle":"অন্ধকারে","merged":true,"masterCell":true,"rowSpan":1,"colSpan":2,"masterCellKey":null,"mergedCells":"\"\\\"\\\\\\\"\\\\\\\\\\\\\\\"[{\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"col\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 2, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"row\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 1}]\\\\\\\\\\\\\\\"\\\\\\\"\\\"\"","createdAt":"2026-03-27T17:16:26.000Z","updatedAt":"2026-03-27T17:16:26.000Z","rowId":768,"resolvedContent":{"id":2080,"newsHeadline":"অন্ধকারে","highlight":"","alternativeHeadline":"","authorId":17,"shortDescription":"কবিরা ছিল বিদ্রোহী সবাই,\r\nকবিতা লিখতে হতো তাই।\r\nছিল না যে কোনো উপায়,\r\nক্ষোভ মিটাতো কবি হৃদয়।","content":"<p>কবিরা ছিল বিদ্রোহী সবাই,</p><p>কবিতা লিখতে হতো তাই।</p><p>ছিল না যে কোনো উপায়,</p><p>ক্ষোভ মিটাতো কবি হৃদয়।</p><p><br></p><p>তোমার লেখা কবিতা</p><p>কেউ নাইবা পারে পড়তে।</p><p>তোমার লেখা কবিতা গান</p><p>হয়তোবা সবাই শুনবে।</p><p><br></p><p>কবিতা পরে থাকে বইয়ের অন্ধকার পাতায়,</p><p>কত দিন পায় না আলো বই আর কবির খাতায়।</p><p>আলো দিয়ে লিখেছিল, যে কবিতা কবি</p><p>সেটা আর নেই কোথাও, অন্ধকার ছবি।</p><p><br></p><p>কবিতা ঠিকই লিখেছেন কবি</p><p>সবগুলো পড়েনি কেহ, কবি ছাড়া।</p><p>কবিতার দুঃখগুলো</p><p>আজ তাই করে ভীষণ তাড়া।</p><p><br></p><p>অন্ধকারে সহস্র কবিতা</p><p>খুঁজতে থাকে আলোকিত কাব্যপ্রেমিক,</p><p>নতুন কোনো হাতে বা চোখে যদি দেখা মিলতো</p><p>তবুও পেতো সান্ত্বনা কিছু কবিতা বা কাব্য।</p><p><br></p><p>কিন্তু তা কি আর হয় শেষে?</p><p>তা তো হবার নয়।</p><p>কবিতা যেগুলো গান হয়ে যায়,</p><p>সেগুলোই কেহ গায়, শোনে সকলে।</p><p><br></p><p>তাও তো সার্থক সে কবিতা, যে গানে।</p><div><br></div>","leadImage":"images/post_image/9n4RI.jpg","thumbImage":"images/post_image/thmb_q3jCI.jpg","imageCaption":"ছবি: এআই","videoLink":"","newsSchedule":"2026-01-15T14:17:33.000Z","metaTitle":"","metaKeywords":"","metaDescription":"","metaImage":"images/post_image/ondhkare02g1D.jpg","status":"published","newsType":"standard","slug":"ondhkare","views":900,"createdAt":"2026-01-08T18:32:16.000Z","updatedAt":"2026-04-02T18:49:25.000Z","Tags":[{"id":31,"name":"কবিতা","slug":"poetry"}],"Categories":[{"id":28,"name":"সাহিত্য","path":"literature"}],"Author":{"id":17,"name":"আব্দুল্লাহ মোহাম্মদ সায়েম"},"GalleryItems":[]}},{"id":3014,"colOrder":3,"width":3,"mergedWith":null,"contentType":"news","tag":"বন্ধুদের লেখা","design":null,"contentId":"2050","contentTitle":"বাবা: নীরব পাহাড়ের মতো এক ভালোবাসা","merged":true,"masterCell":false,"rowSpan":1,"colSpan":1,"masterCellKey":"1-1","mergedCells":null,"createdAt":"2026-03-27T17:16:26.000Z","updatedAt":"2026-03-27T17:16:26.000Z","rowId":768,"resolvedContent":{"id":2050,"newsHeadline":"বাবা: নীরব পাহাড়ের মতো এক ভালোবাসা","highlight":"","alternativeHeadline":"","authorId":81,"shortDescription":"আমরা ‘মা’ বলতেই এক কোমল অনুভূতিতে ভরে উঠি। কিন্তু ‘বাবা’? তিনি যেন ছায়ার মতো—সবসময় আছেন, কিন্তু সবসময় চোখে পড়েন না। তাঁর","content":"$18","leadImage":"images/post_image/zoUT1.jpg","thumbImage":"images/post_image/thmb_aWhc3.jpg","imageCaption":"স্বজল চন্দ্র ও তার বাবা","videoLink":"","newsSchedule":"2026-01-15T14:17:33.000Z","metaTitle":"","metaKeywords":"","metaDescription":"","metaImage":"images/post_image/baba-neerb-paharer-mto-ek-valobasaMzVbR.jpg","status":"published","newsType":"standard","slug":"baba-neerb-paharer-mto-ek-valobasa","views":378,"createdAt":"2025-06-15T21:07:42.000Z","updatedAt":"2026-04-02T18:49:21.000Z","Tags":[{"id":36,"name":"বন্ধুদের লেখা","slug":"written-by-friends"}],"Categories":[{"id":51,"name":"বন্ধুদের লেখা","path":"friends-writing"}],"Author":{"id":81,"name":"স্বজল চন্দ্র (সৌরভ)"},"GalleryItems":[]}},{"id":3015,"colOrder":4,"width":3,"mergedWith":null,"contentType":"news","tag":"অনুষ্ঠান","design":null,"contentId":"2072","contentTitle":"পাঠকবন্ধুদের আন্তর্জাতিক সাফল্য","merged":false,"masterCell":false,"rowSpan":1,"colSpan":1,"masterCellKey":null,"mergedCells":null,"createdAt":"2026-03-27T17: